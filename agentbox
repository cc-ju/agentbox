#!/usr/bin/env bash
# AgentBox - Simplified container environment for Claude development
# Automatically rebuilds when Dockerfile changes and uses ephemeral containers with persistent caches

set -euo pipefail

if ((BASH_VERSINFO[0] < 4)); then
    echo "Error: Bash 4.0 or later required (found ${BASH_VERSION}). This project requires 4.0+ to simplify the code." >&2
    if [[ $OSTYPE == darwin* ]]; then
        echo "Due to GPL licensing, macOS ships with Bash 3.2, which is archaic." >&2
        echo "Try: brew install bash, then ensure /opt/homebrew/bin is in your PATH" >&2
    fi
    exit 1
fi

# Configuration
# Resolve symlinks to get the real script location (allows installation as symlink)
readonly SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
readonly SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
readonly PROJECT_DIR="$(pwd)"
readonly PROJECT_NAME="$(basename "$PROJECT_DIR")"
readonly DOCKERFILE_PATH="${SCRIPT_DIR}/Dockerfile"
readonly ENTRYPOINT_PATH="${SCRIPT_DIR}/entrypoint.sh"
readonly IMAGE_NAME="agentbox:latest"
readonly CONTAINER_PREFIX="agentbox"
readonly PROXY_DIR="${SCRIPT_DIR}/proxy"
readonly PROXY_IMAGE_NAME="agentbox-proxy:latest"

# Set by check_runtime() in main()
RUNTIME=""

# Proxy state (set by start_proxy, cleaned up by cleanup_proxy)
PROXY_NETWORK=""
PROXY_CONTAINER=""
PROXY_IP=""

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m' # No Color

# Helper functions
log_info() { echo -e "${BLUE}ℹ${NC}  $1"; }
log_success() { echo -e "${GREEN}✅${NC} $1"; }
log_warning() { echo -e "${YELLOW}⚠${NC}  $1"; }
log_error() { echo -e "${RED}❌${NC} $1" >&2; }
log_build() { echo -e "${CYAN}🔨${NC} $1"; }

# Detect available container runtime
detect_runtime() {
    if command -v docker &> /dev/null && docker info &> /dev/null; then
        echo "docker"
    elif command -v podman &> /dev/null && podman info &> /dev/null; then
        echo "podman"
    else
        return 1
    fi
}

# Check if a container runtime is available
check_runtime() {
    local runtime
    runtime=$(detect_runtime) || {
        log_error "No container runtime found. Please install Docker or Podman."
        exit 1
    }
    echo "$runtime"
}

# Calculate hash for a file
calculate_hash() {
    local file="$1"
    if [[ -f "$file" ]]; then
        sha256sum "$file" | cut -d' ' -f1
    else
        echo "none"
    fi
}

# Get container name for current project
get_container_name() {
    local project_hash=$(echo -n "$PROJECT_DIR" | sha256sum | cut -c1-12)
    echo "${CONTAINER_PREFIX}-${project_hash}"
}


# Check if image needs rebuild
needs_rebuild() {
    # Calculate current Dockerfile and entrypoint hashes
    local dockerfile_hash=$(calculate_hash "$DOCKERFILE_PATH")
    local entrypoint_hash=$(calculate_hash "$ENTRYPOINT_PATH")
    local combined_hash="${dockerfile_hash}-${entrypoint_hash}"

    # Check if image exists
    if ! $RUNTIME image inspect "$IMAGE_NAME" &> /dev/null; then
        return 0  # Needs rebuild - image doesn't exist
    fi

    # Get stored hash from image
    local stored_hash=$($RUNTIME inspect "$IMAGE_NAME" \
        --format '{{ index .Config.Labels "agentbox.hash" }}' 2>/dev/null || echo "none")

    # Compare hashes
    if [[ "$combined_hash" != "$stored_hash" ]]; then
        return 0  # Needs rebuild
    fi

    return 1  # No rebuild needed
}

# Build Docker image
build_image() {
    local dockerfile_hash=$(calculate_hash "$DOCKERFILE_PATH")
    local entrypoint_hash=$(calculate_hash "$ENTRYPOINT_PATH")
    local combined_hash="${dockerfile_hash}-${entrypoint_hash}"

    log_build "Building AgentBox image (this may take a few minutes on first run)..."

    # Get current user/group IDs
    local user_id=$(id -u)
    local group_id=$(id -g)

    # Build with progress output
    local build_timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    if $RUNTIME build \
        --build-arg USER_ID="${user_id}" \
        --build-arg GROUP_ID="${group_id}" \
        --build-arg USERNAME="agent" \
        --build-arg BUILD_TIMESTAMP=${build_timestamp} \
        --label "agentbox.hash=${combined_hash}" \
        --label "agentbox.version=1.0.0" \
        --label "agentbox.built=${build_timestamp}" \
        -t "$IMAGE_NAME" \
        "$SCRIPT_DIR" ; then
        log_success "Image built successfully!"
        $RUNTIME image prune -f --filter "label=agentbox.version" &>/dev/null || true
        return 0
    else
        log_error "Failed to build image"
        return 1
    fi
}

expand_tilde() {
    local path="$1"
    if [[ "$path" =~ ^~ ]]; then
        echo "${path/#\~/$HOME}"
    else
        echo "$path"
    fi
}

has_path_traversal() {
    local path="$1"
    [[ "$path" =~ \.\. ]]
}

is_absolute_path() {
    local path="$1"
    [[ "$path" =~ ^/ ]]
}

is_critical_system_dir() {
    local path="$1"
    [[ "$path" =~ ^/(bin|sbin|boot|lib|lib64)(/|$) ]]
}

is_system_dir() {
    local path="$1"
    [[ "$path" =~ ^/(etc|var|usr|sys|proc|dev)(/|$) ]]
}

is_duplicate_dir() {
    local path="$1"
    local -n check_dirs_ref=$2

    for existing_dir in "${check_dirs_ref[@]}"; do
        if [[ "$path" == "$existing_dir" ]]; then
            return 0
        fi
    done
    return 1
}

validate_dir_path() {
    local dir="$1"
    local -n validated_dirs_ref=$2
    local project_realpath="$3"

    dir=$(expand_tilde "$dir")

    if has_path_traversal "$dir"; then
        log_error "Path traversal not allowed: $dir"
        return 1
    fi

    if ! is_absolute_path "$dir"; then
        log_error "Directory must be absolute path: $dir"
        return 1
    fi

    if [[ ! -d "$dir" ]]; then
        log_error "Directory not found: $dir"
        return 1
    fi

    local dir_realpath
    dir_realpath=$(realpath "$dir" 2>/dev/null) || {
        log_error "Cannot resolve path: $dir"
        return 1
    }

    if is_critical_system_dir "$dir_realpath"; then
        log_error "Mounting critical system directory not allowed: $dir_realpath"
        return 1
    fi

    if [[ "$dir_realpath" == "$project_realpath" ]]; then
        log_warning "Skipping duplicate: $dir (already mounted as project directory)"
        return 0  # Not an error, just skip
    fi

    if is_duplicate_dir "$dir_realpath" validated_dirs_ref; then
        log_warning "Skipping duplicate directory: $dir"
        return 0  # Not an error, just skip
    fi

    if is_system_dir "$dir_realpath"; then
        log_warning "Mounting system directory: $dir_realpath (proceed with caution)"
    fi

    validated_dirs_ref+=("$dir_realpath")
    return 0
}

# Mount additional dirs to Docker mount options
mount_additional_dirs() {
    local -n mount_opts_ref=$1
    shift
    local extra_dirs=("$@")

    # Return early if no dirs to mount
    if [[ ${#extra_dirs[@]} -eq 0 ]]; then
        return 0
    fi

    for extra_dir in "${extra_dirs[@]}"; do
        mount_opts_ref+=(-v "$extra_dir:$extra_dir:z")
        log_info "Mounting additional directory: $extra_dir"
    done
}

# --- Proxy functions ---

get_proxy_container_name() {
    local project_hash=$(echo -n "$PROJECT_DIR" | sha256sum | cut -c1-12)
    echo "agentbox-proxy-${project_hash}"
}

get_proxy_network_name() {
    local project_hash=$(echo -n "$PROJECT_DIR" | sha256sum | cut -c1-12)
    echo "agentbox-net-${project_hash}"
}

get_proxy_data_dir() {
    local container_name="$1"
    echo "${HOME}/.agentbox/proxy/${container_name}"
}

get_proxy_allowlist_path() {
    local container_name="$1"
    echo "$(get_proxy_data_dir "$container_name")/allowlist.txt"
}

ensure_proxy_allowlist() {
    local container_name="$1"
    local data_dir
    data_dir=$(get_proxy_data_dir "$container_name")
    local allowlist_path="${data_dir}/allowlist.txt"

    mkdir -p "$data_dir"
    if [[ ! -f "$allowlist_path" ]]; then
        cp "${PROXY_DIR}/allowlist.txt" "$allowlist_path"
        log_info "Created default proxy allowlist at ${allowlist_path}"
    fi
}

needs_proxy_rebuild() {
    local containerfile_hash=$(calculate_hash "${PROXY_DIR}/Containerfile")
    local conf_hash=$(calculate_hash "${PROXY_DIR}/tinyproxy.conf")
    local entrypoint_hash=$(calculate_hash "${PROXY_DIR}/entrypoint.sh")
    local allowlist_hash=$(calculate_hash "${PROXY_DIR}/allowlist.txt")
    local combined_hash="${containerfile_hash}-${conf_hash}-${entrypoint_hash}-${allowlist_hash}"

    if ! $RUNTIME image inspect "$PROXY_IMAGE_NAME" &>/dev/null; then
        return 0
    fi

    local stored_hash=$($RUNTIME inspect "$PROXY_IMAGE_NAME" \
        --format '{{ index .Config.Labels "agentbox-proxy.hash" }}' 2>/dev/null || echo "none")

    if [[ "$combined_hash" != "$stored_hash" ]]; then
        return 0
    fi

    return 1
}

build_proxy_image() {
    local containerfile_hash=$(calculate_hash "${PROXY_DIR}/Containerfile")
    local conf_hash=$(calculate_hash "${PROXY_DIR}/tinyproxy.conf")
    local entrypoint_hash=$(calculate_hash "${PROXY_DIR}/entrypoint.sh")
    local allowlist_hash=$(calculate_hash "${PROXY_DIR}/allowlist.txt")
    local combined_hash="${containerfile_hash}-${conf_hash}-${entrypoint_hash}-${allowlist_hash}"

    log_build "Building proxy image..."

    if $RUNTIME build \
        --label "agentbox-proxy.hash=${combined_hash}" \
        --label "agentbox-proxy.version=1.0.0" \
        -f "${PROXY_DIR}/Containerfile" \
        -t "$PROXY_IMAGE_NAME" \
        "$PROXY_DIR"; then
        log_success "Proxy image built successfully!"
        $RUNTIME image prune -f --filter "label=agentbox-proxy.version" &>/dev/null || true
        return 0
    else
        log_error "Failed to build proxy image"
        return 1
    fi
}

cleanup_stale_proxy() {
    local proxy_container_name
    proxy_container_name=$(get_proxy_container_name)
    local proxy_network_name
    proxy_network_name=$(get_proxy_network_name)

    if $RUNTIME inspect "$proxy_container_name" &>/dev/null; then
        log_info "Cleaning up stale proxy container: $proxy_container_name"
        $RUNTIME stop "$proxy_container_name" &>/dev/null || true
        $RUNTIME rm -f "$proxy_container_name" &>/dev/null || true
    fi

    if $RUNTIME network inspect "$proxy_network_name" &>/dev/null; then
        log_info "Cleaning up stale proxy network: $proxy_network_name"
        $RUNTIME network rm "$proxy_network_name" &>/dev/null || true
    fi
}

get_proxy_ip() {
    local container_name="$1"
    local network_name="$2"
    $RUNTIME inspect "$container_name" \
        --format "{{(index .NetworkSettings.Networks \"${network_name}\").IPAddress}}" 2>/dev/null
}

cleanup_proxy() {
    if [[ -n "$PROXY_CONTAINER" ]]; then
        $RUNTIME stop "$PROXY_CONTAINER" &>/dev/null || true
    fi
    if [[ -n "$PROXY_NETWORK" ]]; then
        $RUNTIME network rm "$PROXY_NETWORK" &>/dev/null || true
    fi
}

start_proxy() {
    local agentbox_container_name="$1"
    local proxy_container_name
    proxy_container_name=$(get_proxy_container_name)
    local proxy_network_name
    proxy_network_name=$(get_proxy_network_name)

    cleanup_stale_proxy

    ensure_proxy_allowlist "$agentbox_container_name"

    if needs_proxy_rebuild; then
        if ! build_proxy_image; then
            log_error "Proxy image build failed!"
            exit 1
        fi
    fi

    log_info "Creating isolated network: $proxy_network_name"

    local allowlist_path
    allowlist_path=$(get_proxy_allowlist_path "$agentbox_container_name")

    log_info "Starting proxy container: $proxy_container_name"

    if [[ "$RUNTIME" == "podman" ]]; then
        # Podman rootless (pasta) doesn't support `network connect`, so start
        # the proxy on both networks from the beginning. We also disable DNS on
        # the internal network so that aardvark-dns doesn't shadow the host's
        # upstream resolver with NXDOMAIN responses for external names.
        local host_dns
        host_dns=$(awk '/^nameserver/{print $2; exit}' /etc/resolv.conf 2>/dev/null)
        # systemd-resolved stub (127.0.0.53) doesn't work inside containers
        if [[ -z "$host_dns" || "$host_dns" == 127.* ]]; then
            host_dns="8.8.8.8"
        fi

        $RUNTIME network create --internal --disable-dns "$proxy_network_name" >/dev/null
        $RUNTIME run -d --rm \
            --name "$proxy_container_name" \
            --network podman \
            --network "$proxy_network_name" \
            --dns "$host_dns" \
            -v "${allowlist_path}:/home/tinyproxy/allowlist.txt:z" \
            "$PROXY_IMAGE_NAME" >/dev/null
    else
        $RUNTIME network create --internal "$proxy_network_name" >/dev/null
        $RUNTIME run -d --rm \
            --name "$proxy_container_name" \
            -v "${allowlist_path}:/home/tinyproxy/allowlist.txt:z" \
            "$PROXY_IMAGE_NAME" >/dev/null
        $RUNTIME network connect "$proxy_network_name" "$proxy_container_name"
    fi

    local proxy_ip
    proxy_ip=$(get_proxy_ip "$proxy_container_name" "$proxy_network_name")

    if [[ -z "$proxy_ip" ]]; then
        log_error "Failed to get proxy IP address"
        $RUNTIME stop "$proxy_container_name" &>/dev/null || true
        $RUNTIME network rm "$proxy_network_name" &>/dev/null || true
        exit 1
    fi

    PROXY_NETWORK="$proxy_network_name"
    PROXY_CONTAINER="$proxy_container_name"
    PROXY_IP="$proxy_ip"
    trap cleanup_proxy EXIT

    log_info "Proxy running at ${proxy_ip}:8888"
}

# --- Proxy CLI subcommands ---

proxy_cmd_allow() {
    local domain="$1"
    if [[ -z "$domain" ]]; then
        log_error "Usage: agentbox proxy allow <domain>"
        exit 1
    fi

    local container_name
    container_name=$(get_container_name)
    ensure_proxy_allowlist "$container_name"

    local escaped
    escaped=$(printf '%s' "$domain" | sed 's/\./\\./g')
    local pattern="^${escaped}\$"

    local allowlist_path
    allowlist_path=$(get_proxy_allowlist_path "$container_name")

    if grep -v '^#' "$allowlist_path" 2>/dev/null | grep -qF "$pattern"; then
        log_info "${domain} is already in the allowlist"
        return 0
    fi

    echo "$pattern" >> "$allowlist_path"
    log_success "Added ${domain} to allowlist"
}

proxy_cmd_block() {
    local domain="$1"
    if [[ -z "$domain" ]]; then
        log_error "Usage: agentbox proxy block <domain>"
        exit 1
    fi

    local container_name
    container_name=$(get_container_name)
    ensure_proxy_allowlist "$container_name"
    local allowlist_path
    allowlist_path=$(get_proxy_allowlist_path "$container_name")

    local escaped
    escaped=$(printf '%s' "$domain" | sed 's/\./\\./g')
    local pattern="^${escaped}\$"

    if ! grep -qF "$pattern" "$allowlist_path" 2>/dev/null; then
        log_warning "${domain} not found in allowlist"
        return 0
    fi

    local tmp="${allowlist_path}.tmp"
    grep -vF "$pattern" "$allowlist_path" > "$tmp"
    mv "$tmp" "$allowlist_path"
    log_success "Removed ${domain} from allowlist"
}

proxy_cmd_list() {
    local container_name
    container_name=$(get_container_name)
    ensure_proxy_allowlist "$container_name"
    local allowlist_path
    allowlist_path=$(get_proxy_allowlist_path "$container_name")

    grep -v '^#' "$allowlist_path" | grep -v '^$' | sed 's/^\^//;s/\$$//;s/\\\././g'
}

proxy_cmd_log() {
    local proxy_container_name
    proxy_container_name=$(get_proxy_container_name)

    if ! $RUNTIME inspect "$proxy_container_name" &>/dev/null; then
        log_error "Proxy container is not running"
        exit 1
    fi

    if [[ "${1:-}" == "-f" ]]; then
        $RUNTIME exec "$proxy_container_name" tail -f /home/tinyproxy/tinyproxy.log
    else
        $RUNTIME exec "$proxy_container_name" cat /home/tinyproxy/tinyproxy.log
    fi
}

proxy_cmd_blocked() {
    local proxy_container_name
    proxy_container_name=$(get_proxy_container_name)

    if ! $RUNTIME inspect "$proxy_container_name" &>/dev/null; then
        log_error "Proxy container is not running"
        exit 1
    fi

    $RUNTIME exec "$proxy_container_name" \
        grep "refused on filtered" /home/tinyproxy/tinyproxy.log 2>/dev/null \
        | sed 's/.*Proxying refused on filtered domain "\(.*\)".*/\1/' \
        | sort | uniq -c | sort -rn
}

proxy_cmd_reset() {
    local container_name
    container_name=$(get_container_name)
    local allowlist_path
    allowlist_path=$(get_proxy_allowlist_path "$container_name")

    cp "${PROXY_DIR}/allowlist.txt" "$allowlist_path"
    log_success "Allowlist reset to defaults"
}

cmd_proxy() {
    local subcmd="${1:-help}"
    shift || true

    case "$subcmd" in
        allow)
            proxy_cmd_allow "${1:-}"
            ;;
        block)
            proxy_cmd_block "${1:-}"
            ;;
        list)
            proxy_cmd_list
            ;;
        log)
            proxy_cmd_log "${1:-}"
            ;;
        blocked)
            proxy_cmd_blocked
            ;;
        reset)
            proxy_cmd_reset
            ;;
        help|*)
            cat << PROXYEOF
Proxy management commands:

    agentbox proxy allow <domain>     Add domain to allowlist
    agentbox proxy block <domain>     Remove domain from allowlist
    agentbox proxy list               Show allowed domains
    agentbox proxy log [-f]           Show proxy log (use -f to follow)
    agentbox proxy blocked            Show blocked domains with hit counts
    agentbox proxy reset              Reset allowlist to defaults
PROXYEOF
            ;;
    esac
}

# Run container with --rm (ephemeral)
run_container() {
    local container_name="$1"
    local -n extra_dirs_to_mount=$2
    local tool="$3"
    local ignore_dot_env="$4"
    local enable_proxy="$5"
    shift 5

    # Check if first arg is "shell" mode
    local shell_mode=false
    local admin_mode=false
    if [[ "${1:-}" == "shell" ]]; then
        shell_mode=true
        shift
        # Check if next arg is --admin
        if [[ "${1:-}" == "--admin" ]]; then
            admin_mode=true
            shift
        fi
    fi

    local cmd_args=("$@")

    if [[ "$admin_mode" == "true" ]]; then
        log_success "Starting container for: $PROJECT_NAME (admin shell)"
    else
        log_success "Starting container for: $PROJECT_NAME"
    fi

    # Prepare mount options - mount project at its real host path
    local mount_opts=(
        -v "$PROJECT_DIR:$PROJECT_DIR:z"
        --env "PROJECT_DIR=$PROJECT_DIR"
    )

    mount_additional_dirs mount_opts "${extra_dirs_to_mount[@]}"

    # Mount .gitconfig to temp location for copying (if it exists)
    if [[ -f "${HOME}/.gitconfig" ]]; then
        mount_opts+=(-v "${HOME}/.gitconfig:/tmp/host_gitconfig:ro")
    fi

    # Mount dedicated AgentBox SSH directory
    local agentbox_ssh="${HOME}/.agentbox/ssh"
    if [[ -d "${agentbox_ssh}" ]]; then
        mount_opts+=(-v "${agentbox_ssh}:/home/agent/.ssh:rw")
        log_info "AgentBox SSH directory mounted (read-write)"
    else
        log_warning "SSH not configured. Run 'agentbox ssh-init' to enable SSH operations."
    fi

    # Mount cache directories for package managers
    local cache_dir="${HOME}/.cache/agentbox/${container_name}"
    mkdir -p "${cache_dir}/npm" "${cache_dir}/pip" "${cache_dir}/maven" "${cache_dir}/gradle"

    mount_opts+=(
        -v "${cache_dir}/npm:/home/agent/.npm"
        -v "${cache_dir}/pip:/home/agent/.cache/pip"
        -v "${cache_dir}/maven:/home/agent/.m2"
        -v "${cache_dir}/gradle:/home/agent/.gradle"
    )

    # Mount per-project persistent data
    local project_data_dir="${HOME}/.agentbox/projects/${container_name}"
    local history_dir="${project_data_dir}/history"
    mkdir -p "${history_dir}"

    # Mount history directory (not individual files to avoid file locking issues)
    mount_opts+=(
        -v "${history_dir}:/home/agent/.shell_history"
        --env "HISTFILE=/home/agent/.shell_history/zsh_history"
    )

    if [[ "$tool" == "opencode" ]]; then
        local opencode_config_dir="${HOME}/.config/opencode"
        local opencode_auth_dir="${HOME}/.local/share/opencode"

        mkdir -p "$opencode_config_dir"
        mkdir -p "$opencode_auth_dir"

        mount_opts+=(
            -v "${opencode_config_dir}:/home/agent/.config/opencode"
            -v "${opencode_auth_dir}:/home/agent/.local/share/opencode"
        )

        log_info "OpenCode configuration and auth mounted"
    else
        local claude_dir="${HOME}/.claude"

        mkdir -p "$claude_dir"

        mount_opts+=(
            -v "${claude_dir}:/home/agent/.claude"
            --env "CLAUDE_CONFIG_DIR=/home/agent/.claude"
        )

        log_info "Claude CLI configuration mounted"
    fi

    # Set tool environment variable
    mount_opts+=(--env "TOOL=$tool")

    # Mount host direnv approvals for translation if project has .envrc
    if [[ -f "$PROJECT_DIR/.envrc" ]]; then
        local host_direnv_allow="${HOME}/.local/share/direnv/allow"
        if [[ -d "$host_direnv_allow" ]]; then
            mount_opts+=(-v "${host_direnv_allow}:/tmp/host_direnv_allow:ro")
            log_info "Host direnv approvals will be translated to container"
        fi
    fi

    # Prepare the command to run
    local container_cmd
    if [[ "$shell_mode" == "true" ]]; then
        if [[ "$admin_mode" == "true" ]]; then
            container_cmd=(bash -c "echo '🔒 Admin shell - sudo access enabled' && exec ${cmd_args[*]:-/bin/zsh}")
        else
            container_cmd=("${cmd_args[@]:-/bin/zsh}")
        fi
    else
        # Run tool through zsh to get proper environment
        local tool_cmd
        if [[ "$tool" == "opencode" ]]; then
            tool_cmd="opencode"
        else
            tool_cmd="claude --dangerously-skip-permissions"
        fi

        if [[ ${#cmd_args[@]} -gt 0 ]]; then
            # Properly escape each argument to preserve quoting
            local escaped_args=""
            for arg in "${cmd_args[@]}"; do
                escaped_args+=" $(printf '%q' "$arg")"
            done
            tool_cmd="$tool_cmd$escaped_args"
        fi
        container_cmd=(zsh -c "source ~/.zshrc && exec $tool_cmd")
    fi

    local env_file_args=()
    if [[ "$ignore_dot_env" != "true" ]]; then
        local agentbox_env="${HOME}/.agentbox/.env"
        if [[ -f "$agentbox_env" ]]; then
            env_file_args+=(--env-file "$agentbox_env")
            log_info "Global .env loaded from ~/.agentbox/.env"
        fi

        if [[ -f "$PROJECT_DIR/.env" ]]; then
            env_file_args+=(--env-file "$PROJECT_DIR/.env")
            log_info "Project .env loaded from $PROJECT_DIR/.env"
        fi
    else
        log_info ".env files not loaded (--ignore-dot-env flag set)"
    fi

    # Build port forwarding arguments
    local port_args=()
    for port in "${ports[@]}"; do
        # Support both "3002" and "3002:8080" syntax
        if [[ "$port" =~ ^[0-9]+$ ]]; then
            # Simple port number - map to same port
            port_args+=(-p "${port}:${port}")
            log_info "Port forwarding: ${port} -> ${port}"
        elif [[ "$port" =~ ^[0-9]+:[0-9]+$ ]]; then
            # host:container syntax
            port_args+=(-p "${port}")
            log_info "Port forwarding: ${port}"
        else
            log_warning "Invalid port format: ${port} (use '3002' or '3002:8080')"
        fi
    done

    # Build runtime-specific arguments
    local runtime_args=()
    if [[ "$RUNTIME" == "podman" ]]; then
        runtime_args+=(--userns=keep-id)
    fi

    # Set up proxy if enabled
    local proxy_args=()
    if [[ "$enable_proxy" == "true" ]]; then
        start_proxy "$container_name"
        local proxy_url="http://${PROXY_IP}:8888"
        proxy_args+=(
            --network "$PROXY_NETWORK"
            --env "HTTP_PROXY=${proxy_url}"
            --env "HTTPS_PROXY=${proxy_url}"
            --env "http_proxy=${proxy_url}"
            --env "https_proxy=${proxy_url}"
        )
        log_info "Proxy enabled: outbound traffic restricted to allowlisted domains"
    fi

    # Run ephemeral container with --rm
    $RUNTIME run -it --rm \
        --name "$container_name" \
        --hostname "agentbox-$PROJECT_NAME" \
        "${runtime_args[@]}" \
        "${proxy_args[@]}" \
        "${port_args[@]}" \
        "${mount_opts[@]}" \
        "${env_file_args[@]}" \
        -w "$PROJECT_DIR" \
        --init \
        "$IMAGE_NAME" \
        "${container_cmd[@]}"
}

# Show help
show_help() {
    cat << EOF
AgentBox - Simplified container environment for Claude development

Usage:
    agentbox [OPTIONS] [COMMAND]

Options:
    -h, --help              Show this help message
    --tool TOOL             Choose tool: claude (default) or opencode
    -p PORT                 Forward a port from host to container (can be used multiple times)
    --rebuild               Force rebuild of the image
    --add-dir DIR           Mount additional directory (can be used multiple times)
    --ignore-dot-env        Do not load .env files as environment variables (still mounted)
    --proxy                 Enable proxy to restrict outbound traffic to allowlisted domains

Commands:
    shell [--admin]         Start interactive shell instead of Claude CLI
    ssh-init                Initialize SSH directory for AgentBox
    proxy <subcommand>      Manage proxy allowlist (run 'agentbox proxy help' for details)

    If no command is provided, Claude CLI will be started automatically.
    Use 'shell' command to get a shell instead of Claude CLI.
    Use 'shell --admin' to get a shell with sudo privileges.
    Other commands will be executed inside the container.

Examples:
    agentbox                            # Start Claude CLI for current project
    agentbox --tool opencode            # Start OpenCode instead of Claude
    agentbox -p 3002                    # Forward port 3002
    agentbox -p 3002:8080               # Map host port 3002 to container port 8080
    agentbox --proxy                    # Enable proxy with domain allowlist
    agentbox shell                      # Start interactive shell instead of Claude
    agentbox shell --admin              # Start admin shell with sudo access
    agentbox --add-dir ~/1 --add-dir ~/2  # Add dirs with Claude CLI
    agentbox python script.py           # Run Python script in container
    agentbox --rebuild                  # Force rebuild image
    agentbox ssh-init                   # Set up SSH for AgentBox
    agentbox proxy list                 # Show allowed domains
    agentbox proxy allow example.com    # Add domain to allowlist
    AGENTBOX_TOOL=opencode agentbox     # Use env var to select tool

Containers are ephemeral and automatically removed when you exit.
Package caches and shell history persist between sessions.

All directories are mounted at their full host paths for symlink/path compatibility.

Container Runtime:
    Auto-detected (Docker preferred, Podman fallback)
EOF
}

# Set up dedicated SSH directory for AgentBox
ssh_setup() {
    local agentbox_ssh="${HOME}/.agentbox/ssh"

    log_info "Setting up AgentBox SSH directory..."
    mkdir -p "${agentbox_ssh}"
    chmod 700 "${agentbox_ssh}"


    # Copy known_hosts if it exists
    if [[ -f "${HOME}/.ssh/known_hosts" ]]; then
        cp "${HOME}/.ssh/known_hosts" "${agentbox_ssh}/known_hosts"
        chmod 600 "${agentbox_ssh}/known_hosts"
        log_success "Copied known_hosts from ~/.ssh"
    fi

    # Check if AgentBox key already exists
    if [[ -f "${agentbox_ssh}/id_ed25519" ]]; then
        log_info "AgentBox SSH key already exists"
    else
        log_info "Generating dedicated SSH key for AgentBox..."
        ssh-keygen -t ed25519 -f "${agentbox_ssh}/id_ed25519" -C "agentbox@$(hostname)" -N ""
        log_success "Generated new SSH key: ${agentbox_ssh}/id_ed25519"
        echo ""
        log_info "Add this public key to your Git provider:"
        echo ""
        cat "${agentbox_ssh}/id_ed25519.pub"
        echo ""
        log_info "Alternatively, replace the keys in ${agentbox_ssh}/ with your desired keys"
    fi

    log_success "SSH setup complete! Directory: ${agentbox_ssh}"
    log_info "AgentBox will use this directory for all SSH operations."
}

# Main execution
main() {
    # Parse arguments
    local force_rebuild=false
    local shell_mode=false
    local admin_mode=false
    local cmd_args=()
    declare -a ports=()
    local extra_dirs=()
    local tool="${AGENTBOX_TOOL:-claude}"
    local ignore_dot_env=false
    local enable_proxy=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            --rebuild)
                force_rebuild=true
                shift
                ;;
            -p)
                shift
                if [[ -z "${1:-}" ]]; then
                    log_error "Port argument requires a value"
                    exit 1
                fi
                ports+=("$1")
                shift
                ;;
            --add-dir)
                shift
                if [[ -z "${1:-}" ]]; then
                    log_error "--add-dir requires a directory path"
                    exit 1
                fi
                extra_dirs+=("$1")
                shift
                ;;
            --tool)
                shift
                if [[ -z "${1:-}" ]]; then
                    log_error "--tool requires a value (claude or opencode)"
                    exit 1
                fi
                tool="$1"
                shift
                ;;
            --ignore-dot-env)
                ignore_dot_env=true
                shift
                ;;
            --proxy)
                enable_proxy=true
                shift
                ;;
            proxy)
                shift
                RUNTIME=$(check_runtime)
                cmd_proxy "$@"
                exit 0
                ;;
            shell)
                shell_mode=true
                shift
                # Check if next arg is --admin
                if [[ "${1:-}" == "--admin" ]]; then
                    admin_mode=true
                    shift
                fi
                # Remaining args become shell commands
                cmd_args=("$@")
                break
                ;;
            ssh-init)
                ssh_setup
                exit 0
                ;;
            *)
                cmd_args+=("$1")
                shift
                ;;
        esac
    done

    # Validate tool selection
    if [[ "$tool" != "claude" && "$tool" != "opencode" ]]; then
        log_error "Invalid tool: $tool (must be 'claude' or 'opencode')"
        exit 1
    fi

    # Check runtime
    RUNTIME=$(check_runtime)
    log_info "Using container runtime: $RUNTIME"

    # Get container name for current project
    local container_name=$(get_container_name)

    # Validate dir paths (batch all errors so user sees all problems at once)
    local project_realpath
    project_realpath=$(realpath "$PROJECT_DIR")
    local validated_dirs=()
    local validation_failed=false
    for dir in "${extra_dirs[@]}"; do
        if ! validate_dir_path "$dir" validated_dirs "$project_realpath"; then
            validation_failed=true
        fi
    done

    if [[ "$validation_failed" == "true" ]]; then
        exit 1
    fi

    # Check if rebuild is needed or forced
    if [[ "$force_rebuild" == "true" ]] || needs_rebuild; then
        if [[ "$force_rebuild" == "true" ]]; then
            log_info "Forcing image rebuild..."
        else
            log_info "Dockerfile or entrypoint changed, rebuilding automatically..."
        fi

        if ! build_image; then
            log_error "Build failed!"
            exit 1
        fi

    fi

    # Run or attach to container
    if [[ "$shell_mode" == "true" ]]; then
        if [[ "$admin_mode" == "true" ]]; then
            run_container "$container_name" validated_dirs "$tool" "$ignore_dot_env" "$enable_proxy" "shell" "--admin" "${cmd_args[@]}"
        else
            run_container "$container_name" validated_dirs "$tool" "$ignore_dot_env" "$enable_proxy" "shell" "${cmd_args[@]}"
        fi
    else
        run_container "$container_name" validated_dirs "$tool" "$ignore_dot_env" "$enable_proxy" "${cmd_args[@]}"
    fi
}

# Run main function
main "$@"
